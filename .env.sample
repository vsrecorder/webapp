ENV=

VSRECORDER_DOMAIN=
VSRECORDER_JWT_SECRET=

AUTH_URL=
AUTH_SECRET=
AUTH_TRUST_HOST=

# FIREBASE_CLIENT_EMAIL / FIREBASE_PRIVATE_KEY は Firebase Admin SDK 用のサービスアカウント認証情報。
# デフォルトの App Engine default service account は Editor ロール(プロジェクト内の
# ほぼ全リソースへの読み書き権限)を持つ場合があるため使用しないこと。
# 必ず Firebase Authentication の操作(verifyIdToken/updateUser/deleteUser)に
# 必要な最小権限(例: roles/firebaseauth.admin)のみを持つ専用サービスアカウントを
# 作成し、その鍵を使用すること。
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_MEASUREMENT_ID=

# 施策0-6: 記録0件ユーザー向け「最初の記録を作る」CTAの表示トグル。
# 未設定なら有効。緊急停止・段階公開したい場合のみ false を設定する。
FIRST_RECORD_CTA_ENABLED=

SAKURA_OBJECTSTORAGE_ACCESS_KEY_ID=
SAKURA_OBJECTSTORAGE_SECRET_ACCESS_KEY=
SAKURA_OBJECTSTORAGE_ENDPOINT=
SAKURA_OBJECTSTORAGE_REGION=
SAKURA_OBJECTSTORAGE_BUCKET_NAME=
SAKURA_OBJECTSTORAGE_CDN_URL=
